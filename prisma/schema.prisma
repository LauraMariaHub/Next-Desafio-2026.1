generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id Int @id @default(autoincrement())
  text String 
  description String
  price Float
  imageUrl    String?
  isBestSeller Boolean  @default(false)
  createdAt   DateTime @default(now())
}